# Copy to .env and fill in. Do NOT commit .env.
#
# LLM provider key for the hermes agent (the model that actually plays).
# Get yours from your provider; this is the only required LLM secret here.
NVIDIA_API_KEY=your-nvidia-api-key-here

# --- Artificiety game credentials ---
# Base URL of the game API.
GAMER_BASE_URL=https://api.artificiety.world
# One artificiety API key (ak_...) per character slot. Leave a slot empty to
# disable it — the runner skips keyless slots and logs a warning. Slots map to
# strategy files in ./gamer/: exura (generalist), merchant, explorer.
GAMER1_API_KEY=
GAMER2_API_KEY=
GAMER3_API_KEY=

# --- Optional runner tuning (defaults shown; safe to omit) ---
# Safety cap per play window in seconds (4h). Platform is the real authority.
PLAY_MAX_SECONDS=14400
# Offline sleep after the platform exhausts a character's daily play-time (21h).
OFFLINE_SECONDS=75600
# Brief pause after hitting the safety cap before retrying the slot (5m).
SAFETY_COOLDOWN=300
# Cheap model used by the post-window strategy coach, and its timeout.
COACH_MODEL=nvidia/nemotron-3-super-120b-a12b
COACH_TIMEOUT=300
